{
  "name": "aula_playwright",
  "version": "1.0.0",
  "description": "Crescer: Automação de testes com Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/home/home.spec.js -g \"Busca\"",
    "test:filters": "playwright test tests/home/home.spec.js -g \"filtrar\"",
    "test:home": "playwright test tests/home/home.spec.js",
    "test:cadastro": "playwright test tests/login/cadastro.spec.js",
    "test:login": "playwright test tests/login/login.spec.js",
    "test:login:todos": "playwright test tests/login",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/home/home.spec.js -g \"Visual\"",
    "test:visual:update": "playwright test tests/home/home.spec.js -g \"Visual\" --update-snapshots",
    "report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5"
  }
}
